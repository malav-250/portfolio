# ─── Required ────────────────────────────────────────────────
# PostgreSQL connection string. For Vercel, use a managed Postgres
# provider (Neon, Supabase, RDS) and point at their pooler endpoint
# (PgBouncer / data API) so serverless can scale.
#
# Examples:
#   postgres://user:pass@db.neon.tech/portfolio?sslmode=require
#   postgres://user:pass@db.supabase.co:6543/postgres?pgbouncer=true
DATABASE_URL=

# Secret used to gate /admin and /api/admin/stats. Pass it as
# ?secret=... the first time you visit /admin; the page will store
# it in localStorage afterward. Use a long random string.
ADMIN_SECRET=

# ─── Optional ────────────────────────────────────────────────
# IPinfo API token for IP enrichment (free tier: 50k req/month).
# If unset, we hit the unauthenticated endpoint with much lower limits.
# Sign up at https://ipinfo.io
IPINFO_TOKEN=

# Upstash Redis REST credentials for production-grade rate limiting.
# If both are set, /api/track uses Redis-backed sliding-window limits.
# Otherwise, an in-memory limiter is used (best-effort on serverless).
# Sign up at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
